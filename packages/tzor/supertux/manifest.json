{
  "version": "0.7.0",
  "package": "supertux",
  "workswith": ["linux"],
  "installenv_linux": {
    "TUXBIN": "https://github.com/universeOS-project/universeOS-project.github.io/releases/download/upm-supertux/SuperTux.AppImage"
  },
  "installscript_linux": [
    "cd /tmp",
    "wget -q --show-progress $TUXBIN -O SuperTux.AppImage",
    "cp ./SuperTux.AppImage $UNIBIN/supertux",
    "chmod +x $UNIBIN/supertux"
  ]
} 
